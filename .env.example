# ============================================
# BRUTUS LAVAJATO - CONFIGURAÇÃO DE AMBIENTE
# ============================================
# IMPORTANTE: Este é um arquivo de EXEMPLO.
# Copie para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env no Git!

# ── PLATE RECOGNIZER ───────────────────────
# API Key para reconhecimento de placas (95-99% precisão)
# Gere em: https://app.platerecognizer.com/
# Plano gratuito: 2.500 reconhecimentos/mês
PLATE_RECOGNIZER_API_KEY=sua_plate_recognizer_api_key_aqui

# ── GROQ AI (GRATUITO) ─────────────────────
# API Key para detectar marca, modelo e cor do veículo
# Gere em: https://console.groq.com/keys
# Plano gratuito: 14.400 requisições/dia (100% grátis!)
# Modelo usado: llama-3.2-90b-vision-preview
GROQ_API_KEY=sua_groq_api_key_aqui

# ── APLICAÇÃO ──────────────────────────────
# URL onde o app está hospedado
APP_URL=http://localhost:3000

# Origens permitidas para CORS (separadas por vírgula)
# Em produção, adicione apenas seus domínios
ALLOWED_ORIGINS=https://brutusvix.vercel.app/,https://brutusvix.vercel.app/

# ── SUPABASE ───────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) - segura para frontend
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave privada (service_role) - APENAS BACKEND, NUNCA EXPOR
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ── JWT SECRET ─────────────────────────────
# Secret para assinar tokens JWT do backend
# Gere com: openssl rand -base64 64
# OU online: https://generate-secret.vercel.app/64
JWT_SECRET=seu_jwt_secret_aqui
